{
  "name": "youtube-safari",
  "version": "0.1.0",
  "description": "Thin YouTube-only IINA plugin with Safari cookies and Referer headers",
  "scripts": {
    "build": "rm -rf dist && parcel build .",
    "watch": "parcel watch ."
  },
  "author": "jarobinson",
  "license": "MIT",
  "devDependencies": {
    "iina-plugin-definition": "^0.99.3",
    "parcel": "^2.12.0",
    "typescript": "^5.9.3"
  },
  "targets": {
    "main": false,
    "entry": {
      "distDir": "./dist/",
      "source": "src/index.ts",
      "isLibrary": false
    },
    "globalEntry": {
      "distDir": "./dist/",
      "source": "src/global.ts",
      "isLibrary": false
    }
  }
}