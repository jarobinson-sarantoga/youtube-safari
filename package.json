{
  "name": "youtube-safari",
  "version": "0.2.1",
  "description": "Thin YouTube-only IINA plugin with Safari cookies and Referer headers",
  "scripts": {
    "build": "rm -rf dist && parcel build . && node --check dist/index.js && node --check dist/global.js",
    "test": "node --test scripts/parse.test.mjs && node --check dist/index.js",
    "watch": "parcel watch ."
  },
  "author": "jarobinson",
  "license": "MIT",
  "devDependencies": {
    "iina-plugin-definition": "^0.99.3",
    "parcel": "^2.12.0",
    "typescript": "^5.9.3"
  },
  "targets": {
    "main": false,
    "entry": {
      "distDir": "./dist/",
      "source": "src/index.ts",
      "isLibrary": false
    },
    "globalEntry": {
      "distDir": "./dist/",
      "source": "src/global.ts",
      "isLibrary": false
    },
    "sidebarShell": {
      "distDir": "./dist/",
      "source": "src/sidebar/shell.ts",
      "context": "browser",
      "isLibrary": false
    },
    "parseCore": {
      "distDir": "./dist/",
      "source": "src/sidebar/parse-core.ts",
      "context": "node",
      "isLibrary": true,
      "outputFormat": "esmodule"
    }
  },
  "dependencies": {
    "youtubei.js": "^17.0.1"
  }
}
